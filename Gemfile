source "https://rubygems.org"

# This matches the GitHub Pages environment
gem "github-pages", group: :jekyll_plugins

# Required for Ruby 3.0+ (fixes the Exit Code 1/Webrick crash)
gem "webrick"

# Required for Windows to handle timezones correctly
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]